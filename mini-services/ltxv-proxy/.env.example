# LTXV Proxy Configuration

# ComfyUI API URL
COMFY_URL=http://127.0.0.1:8188

# Output directory for generated videos
OUTPUT_DIR=D:\local-video-proxy\generated

# Allow fallback to latest IPAdapter image if body.image is missing
LTX_ALLOW_LATEST_IMAGE_FALLBACK=false

# Fallback image search directory (Comfy IPAdapter output)
COMFY_IPADAPTER_OUTPUT_DIR=D:\comfy-image-reference-proxy\generated

# Default workflow file (relative to this directory)
WORKFLOW_FILE=workflow_ltxv_i2v.json

# Server port
PORT=9200
